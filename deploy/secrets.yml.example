# Secret values for local development.
# Copy this file to secrets.yml and fill in the values.
# secrets.yml is gitignored — never commit it.
#
# Apply secrets before starting the dev stack:
#   make secrets   (writes each key to secrets/<key>)
#   make dev       (runs make secrets automatically)

# Gemini API key — get from https://aistudio.google.com/apikey
gemini_api_key: YOUR_GEMINI_API_KEY_HERE

# Veo API key — for video generation via proxy (e.g. ai.ai666.net)
veo_api_key: YOUR_VEO_API_KEY_HERE

# kie.ai API key — get from https://kie.ai/api-key
# Only required when VIDEO_PROVIDER=kie (multi-model REST video generation)
kie_api_key: YOUR_KIE_API_KEY_HERE

# DeepSeek API key — get from https://platform.deepseek.com/api_keys
deepseek_api_key: YOUR_DEEPSEEK_API_KEY_HERE

# Langfuse (LLM observability) — project keys from your self-hosted Langfuse UI
# (Settings → API Keys). Only used when LANGFUSE_ENABLED=true (set in config.yml).
# Host is non-secret and lives in config.yml (LANGFUSE_HOST).
langfuse_public_key: YOUR_LANGFUSE_PUBLIC_KEY_HERE
langfuse_secret_key: YOUR_LANGFUSE_SECRET_KEY_HERE
