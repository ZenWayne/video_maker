# Dev Dockerfile - for development with hot reload

FROM node:20-alpine
WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source
COPY . .

# Dev server port
EXPOSE 5173

ENV VITE_API_BASE=http://localhost:8001

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
